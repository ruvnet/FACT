{
  "name": "fact-cli",
  "version": "1.0.0",
  "description": "FACT (Fast Augmented Context Tools) - High-performance CLI with WASM integration for cognitive template processing",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "fact": "bin/fact.js",
    "fact-mcp": "bin/fact-mcp.js"
  },
  "files": [
    "lib/**/*",
    "bin/**/*",
    "types/**/*",
    "wasm/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && npm run compile && npm run copy-wasm",
    "compile": "tsc --build",
    "clean": "rimraf lib bin types",
    "copy-wasm": "cp -r ../wasm/pkg/* wasm/",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write 'src/**/*.{ts,js,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,js,json}'",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test && npm run lint",
    "prepack": "npm run build",
    "postinstall": "node scripts/postinstall.js",
    "dev": "ts-node src/index.ts",
    "start": "node lib/index.js",
    "benchmark": "node lib/benchmark.js",
    "docs": "typedoc src --out docs",
    "size-check": "bundlesize",
    "security-audit": "npm audit && snyk test"
  },
  "keywords": [
    "fact",
    "cli",
    "wasm",
    "cognitive-templates",
    "mcp",
    "performance",
    "ai",
    "tools",
    "rust",
    "webassembly",
    "framework",
    "autonomous",
    "fast",
    "augmented",
    "context"
  ],
  "author": "ruv <ruvnet@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruvnet/FACT.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/ruvnet/FACT/issues"
  },
  "homepage": "https://github.com/ruvnet/FACT#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "dependencies": {
    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "inquirer": "^9.2.0",
    "fs-extra": "^11.1.1",
    "cross-spawn": "^7.0.3",
    "glob": "^10.3.0",
    "yaml": "^2.3.2",
    "dotenv": "^16.3.1",
    "semver": "^7.5.4",
    "update-notifier": "^7.0.0",
    "debug": "^4.3.4",
    "winston": "^3.10.0",
    "node-fetch": "^3.3.2",
    "ws": "^8.13.0",
    "jsonrpc-lite": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@types/jest": "^29.5.3",
    "@types/fs-extra": "^11.0.1",
    "@types/cross-spawn": "^6.0.2",
    "@types/semver": "^7.5.0",
    "@types/debug": "^4.1.8",
    "@types/ws": "^8.5.5",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "jest": "^29.6.2",
    "ts-jest": "^29.1.1",
    "eslint": "^8.47.0",
    "prettier": "^3.0.2",
    "rimraf": "^5.0.1",
    "bundlesize": "^0.18.1",
    "typedoc": "^0.24.8",
    "snyk": "^1.1200.0"
  },
  "peerDependencies": {
    "@fact/wasm-core": "^0.1.0"
  },
  "bundlesize": [
    {
      "path": "./lib/index.js",
      "maxSize": "500kb"
    },
    {
      "path": "./wasm/*.wasm",
      "maxSize": "300kb"
    }
  ],
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/types/**/*"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}